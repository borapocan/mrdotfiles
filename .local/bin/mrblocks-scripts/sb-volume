#!/usr/bin/env sh

case $BLOCK_BUTTON in
    1) st -e pavucontrol; pkill -RTMIN+3 "${STATUSBAR:-dwmblocks}" ;;
    2) pamixer -t ;;
    4) pamixer --increase 1 ;;
    5) pamixer --decrease 1 ;;
    3) notify-send "📢 Volume" "Scroll to change volume. Middle click to mute." ;;
esac

vol="$(pamixer --get-volume 2>/dev/null)"
[ -z "$vol" ] && echo "🔇" && exit

[ "$(pamixer --get-mute 2>/dev/null)" = "true" ] && echo "🔇" && exit

vol="$(printf "%.0f" "$vol")"
case 1 in
    $((vol >= 70)) ) icon="🔊" ;;
    $((vol >= 30)) ) icon="🔉" ;;
    $((vol >= 1))  ) icon="🔈" ;;
    * ) echo "🔇" && exit ;;
esac
printf "%s %s " "$icon" "$vol%"

